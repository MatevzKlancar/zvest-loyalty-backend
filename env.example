# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Server Configuration
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info

# POS Provider API Keys
# Use this format: "Provider1:api_key_1,Provider2:api_key_2"
# Example: POS_PROVIDERS="Coffee POS:pos-coffee-12345678-abcdef123456,Restaurant POS:pos-restaurant-87654321-fedcba654321"
POS_PROVIDERS=""

# Push Notification Delivery Kill Switch
# When false, the service builds + records messages with status='dry_run' but
# does NOT call Expo. Flip to true once the native app's favorites flow is live
# and we're ready to actually deliver pushes to users.
PUSH_NOTIFICATIONS_DELIVERY_ENABLED=false